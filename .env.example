# DarwinFi Environment Variables

# Wallet (NEVER commit .env with real keys)
PRIVATE_KEY=0x_your_wallet_private_key_here

# RPC Endpoints
BASE_RPC_URL=https://mainnet.base.org
BASE_TESTNET_RPC_URL=https://sepolia.base.org
CELO_RPC_URL=https://forno.celo.org

# AI Providers
ANTHROPIC_API_KEY=sk-ant-your-key-here
VENICE_API_KEY=your-venice-api-key-here

# Uniswap V3 Router (Base Mainnet)
UNISWAP_V3_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481
UNISWAP_V3_QUOTER=0x3d4e44Eb1374240CE5F1B871ab261CD16335B76a

# Contract Addresses (filled after deployment)
DARWIN_VAULT_ADDRESS=
STRATEGY_EXECUTOR_ADDRESS=
PERFORMANCE_LOG_ADDRESS=

# Trading Config
EVOLUTION_INTERVAL_HOURS=4
MIN_TRADES_FOR_PROMOTION=5
INITIAL_BUDGET_PER_STRATEGY_USD=25

# Synthesis Hackathon
SYNTHESIS_API_KEY=sk-synth-your-key-here

# ENS/Basenames
BASENAME_TARGET=darwinfi.base.eth

# Filecoin/IPFS (Storacha)
W3UP_EMAIL=
W3UP_SPACE_DID=
