{
  "name": "darwinfi",
  "version": "0.1.0",
  "description": "Autonomous self-evolving trading agent with Darwinian strategy competition",
  "main": "dist/agent/darwin-agent.js",
  "scripts": {
    "build": "hardhat compile && tsc && cp src/dashboard/index.html dist/src/dashboard/",
    "start": "ts-node src/agent/darwin-agent.ts",
    "dashboard": "ts-node -e \"require('dotenv').config(); require('./src/dashboard/server').startDashboard(Number(process.env.DASHBOARD_PORT) || 3502)\"",
    "deploy:base-testnet": "hardhat run scripts/deploy.ts --network baseTestnet",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:celo": "hardhat run scripts/deploy.ts --network celo",
    "test": "hardhat test",
    "lint": "eslint src/ --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@openzeppelin/contracts": "^5.6.1",
    "@uniswap/sdk-core": "^7.12.2",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "express": "^4.21.1",
    "hardhat": "^2.28.6",
    "openai": "^6.32.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^3.0.0",
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "chai": "^6.2.2",
    "eslint": "^10.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "trading",
    "defi",
    "autonomous-agent",
    "darwinian",
    "uniswap",
    "base"
  ],
  "author": "Maxwell Morgan",
  "license": "MIT"
}
