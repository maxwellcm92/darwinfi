{
  "name": "darwinfi",
  "version": "0.1.0",
  "description": "Autonomous self-evolving trading agent with Darwinian strategy competition",
  "main": "dist/agent/darwin-agent.js",
  "scripts": {
    "build": "hardhat compile && tsc && cp src/dashboard/index.html dist/src/dashboard/",
    "start": "ts-node src/agent/darwin-agent.ts",
    "dashboard": "ts-node -e \"require('dotenv').config(); require('./src/dashboard/server').startDashboard(Number(process.env.DASHBOARD_PORT) || 3502)\"",
    "deploy:base-testnet": "hardhat run scripts/deploy.ts --network baseTestnet",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:celo": "hardhat run scripts/deploy.ts --network celo",
    "test": "hardhat test",
    "lint": "eslint src/ --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@lit-protocol/auth-helpers": "^8.2.1",
    "@lit-protocol/contracts-sdk": "^8.0.0-alpha.0",
    "@lit-protocol/lit-node-client": "^8.0.0-alpha.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@openzeppelin/contracts": "^5.6.1",
    "@storacha/client": "^2.1.2",
    "@uniswap/sdk-core": "^7.12.2",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "express": "^4.21.1",
    "hardhat": "^2.28.6",
    "openai": "^6.32.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "chai": "^6.2.2",
    "eslint": "^10.0.3",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "trading",
    "defi",
    "autonomous-agent",
    "darwinian",
    "uniswap",
    "base"
  ],
  "author": "Maxwell Morgan",
  "license": "MIT"
}
