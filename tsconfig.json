{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@agent/*": ["./src/agent/*"],
      "@trading/*": ["./src/trading/*"],
      "@chain/*": ["./src/chain/*"],
      "@integrations/*": ["./src/integrations/*"]
    }
  },
  "include": ["src/**/*", "scripts/**/*", "test/**/*", "hardhat.config.ts"],
  "exclude": ["node_modules", "dist", "artifacts", "cache"]
}
